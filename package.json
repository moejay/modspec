{
  "name": "@moejay/modspec",
  "version": "0.6.0",
  "description": "Spec-driven dependency graph visualizer with composable modules and feature tracking",
  "type": "module",
  "bin": {
    "modspec": "./bin/modspec.js",
    "@moejay/modspec": "./bin/modspec.js"
  },
  "main": "./src/parser.js",
  "files": [
    "bin/",
    "src/",
    "skills/",
    "README.md"
  ],
  "keywords": [
    "spec",
    "dependency-graph",
    "visualization",
    "gherkin",
    "markdown",
    "frontmatter",
    "d3",
    "modular",
    "architecture"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moejay/modspec.git"
  },
  "homepage": "https://moejay.github.io/modspec",
  "scripts": {
    "test": "vitest run --reporter=default --reporter=json --outputFile=results/vitest-results.json",
    "test:watch": "vitest"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "gray-matter": "^4.0.3",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@amiceli/vitest-cucumber": "^5.2.1",
    "d3": "^7.9.0",
    "jsdom": "^29.1.1",
    "vitest": "^3.1.1"
  }
}
